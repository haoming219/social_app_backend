{
  "spec_dir": "src",
  "spec_files": [
    "**/*.spec.js"
  ],
  "helpers": [
    "helpers/**/*.js"
  ],
  "reporters": [
    {
      "name": "jasmine-reporters",
      "options": {
        "junitReporter": {
          "outputDir": "test_results",
          "outputFile": "junit.xml"
        }
      }
    }
  ]
}

